# 서버 설정
PORT=3005

# 데이터베이스 설정 (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_DATABASE=api_key_manager

# OpenAI API 키 (민감)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AES-256-GCM 암호화 키 (민감)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_character_hex_string_here

# API 키 접두사
API_KEY_PREFIX=team-sk

# --- Manual RAG (USER_MANUAL.md → Chroma, LangChain) ---
# 아래 URL은 예시입니다. 실제 배포 시 환경에 맞는 OpenAI 호환 게이트웨이 호스트만 설정하세요.
# MANUAL_MD_PATH=
# MANUAL_CHUNK_OVERRIDES_PATH=
CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION_NAME=api_gateway_user_manual
# EMBEDDING_GATEWAY_BASE_URL=https://your-openai-compatible-gateway.example.com
EMBEDDING_GATEWAY_BASE_URL=
EMBEDDING_GATEWAY_API_KEY=
EMBEDDING_OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
MANUAL_RAG_TOP_K=10
MANUAL_RAG_CHAT_MODEL=gpt-4.1-mini
MANUAL_RAG_CHAT_TIMEOUT_MS=60000
# RAG_CHAT_GATEWAY_BASE_URL=https://your-openai-compatible-gateway.example.com
RAG_CHAT_GATEWAY_BASE_URL=
RAG_CHAT_GATEWAY_API_KEY=
MANUAL_RAG_REINDEX_SECRET=
