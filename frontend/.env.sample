# Gateway API Base URL
# 프로덕션: https://your-gateway-domain.com
VITE_GATEWAY_URL=

# Cross-Origin Token Provider 설정
# 로컬: http://localhost:8080/token-provider
# 프로덕션: https://your-main-domain.com/token-provider
VITE_TOKEN_PROVIDER_URL=

# 메인 도메인 Origin
# 로컬: http://localhost:8080
# 프로덕션: https://your-main-domain.com
VITE_MAIN_DOMAIN_ORIGIN=

# Firebase Configuration
# ⚠️ 중요: 실제 Firebase 프로젝트 정보를 입력하세요
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id
VITE_FIREBASE_DATABASE_URL=your_firebase_database_url
